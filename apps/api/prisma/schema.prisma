// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?

generator client {
  provider            = "prisma-client"
  output              = "../generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = ""
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  goal
  ownGoal
  penaltyGoal
  penaltyMiss
  yellowCard
  redCard
  injury
  shootoutGoal
  shootoutMiss
}

enum MatchType {
  group
  quarterFinal
  semiFinal
  final
  thirdPlace
}

model Tournament {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  date      String  @default(dbgenerated("TO_CHAR(NOW(), 'MM/YYYY')"))
  isDeleted Boolean @default(false)
  teams     Team[]
  groups    Group[]
}

model Team {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  logoUrl      String?
  tournamentId Int
  Tournament   Tournament @relation(fields: [tournamentId], references: [id])
  players      Player[]
  homeMatches  Match[]    @relation("HomeTeamMatches")
  awayMatches  Match[]    @relation("AwayTeamMatches")
  groupId      Int?
  group        Group?      @relation(fields: [groupId], references: [id])
}

model Player {
  id          Int          @id @default(autoincrement())
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  teamId      Int?
  team        Team?        @relation(fields: [teamId], references: [id])
  events      MatchEvent[]
}

model Match {
  id                 Int          @id @default(autoincrement())
  timeOfMatch        DateTime
  homeTeamId         Int?
  awayTeamId         Int?
  homeGoals          Int          @default(0)
  awayGoals          Int          @default(0)
  homeTeam           Team?        @relation("HomeTeamMatches", fields: [homeTeamId], references: [id])
  awayTeam           Team?        @relation("AwayTeamMatches", fields: [awayTeamId], references: [id])
  events             MatchEvent[]
  matchType          MatchType
  isActive           Boolean      @default(false)
  timerIsRunning     Boolean      @default(false)
  timerStartedAt     DateTime?
  timerAccumulatedMs Int          @default(0)
  timerLastSyncedAt  DateTime?
}

model MatchEvent {
  id            Int       @id @default(autoincrement())
  minute        Int
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId       Int
  player        Player?   @relation(fields: [playerId], references: [id])
  playerId      Int?
  eventType     EventType
  isForHomeTeam Boolean
}

model Group {
  id           Int        @id @default(autoincrement())
  name         String
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  teams        Team[]
  @@unique([name, tournamentId])
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
